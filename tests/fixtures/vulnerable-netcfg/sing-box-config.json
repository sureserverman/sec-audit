{
  "log": { "level": "info" },

  "dns": {
    "servers": [
      { "address": "8.8.8.8" }
    ]
  },

  "inbounds": [
    {
      "type": "socks",
      "listen": "0.0.0.0",
      "listen_port": 1080
    },
    {
      "type": "vless",
      "listen": "::",
      "listen_port": 443,
      "users": [{ "uuid": "00000000-0000-0000-0000-000000000000" }],
      "tls": {
        "enabled": true,
        "insecure": true
      }
    }
  ],

  "outbounds": [
    { "type": "direct", "tag": "direct" }
  ],

  "experimental": {
    "clash_api": { "external_controller": ":9090" }
  },

  "INVALID_FIELD": "this triggers a sing-box check failure"
}
