[
  {
    "RuleID": "aws-access-token",
    "Description": "AWS Access Key",
    "StartLine": 3,
    "EndLine": 3,
    "StartColumn": 20,
    "EndColumn": 39,
    "Match": "AWS_ACCESS_KEY_ID=REDACTED",
    "Secret": "REDACTED",
    "File": ".env",
    "Fingerprint": ".env:aws-access-token:3"
  },
  {
    "RuleID": "generic-api-key",
    "Description": "Generic API Key",
    "StartLine": 8,
    "EndLine": 8,
    "StartColumn": 12,
    "EndColumn": 52,
    "Match": "api_token = \"REDACTED\"",
    "Secret": "REDACTED",
    "File": "app/config.py",
    "Fingerprint": "app/config.py:generic-api-key:8"
  }
]
