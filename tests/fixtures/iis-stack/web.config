<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <appSettings>
    <add key="Environment" value="Production" />
    <add key="SiteName" value="ContosoPortal" />
  </appSettings>

  <connectionStrings>
    <add name="DefaultConnection"
         connectionString="Server=.\SQLEXPRESS;Database=Contoso;Integrated Security=true;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" maxRequestLength="1048576" />
    <authentication mode="Forms">
      <forms loginUrl="~/Account/Login" timeout="2880" />
    </authentication>
    <!-- INTENTIONAL: detailed ASP.NET errors leak stack traces to remote clients -->
    <customErrors mode="Off" />
    <pages validateRequest="false" />
  </system.web>

  <system.webServer>
    <!-- INTENTIONAL: directory listings exposed when no default document present -->
    <directoryBrowse enabled="true" />

    <defaultDocument>
      <files>
        <add value="Default.aspx" />
      </files>
    </defaultDocument>

    <!-- INTENTIONAL: full IIS error screens returned to remote callers -->
    <httpErrors errorMode="Detailed" existingResponse="PassThrough" />

    <security>
      <!-- INTENTIONAL: TLS 1.0 and 1.1 still enabled on the binding -->
      <access sslFlags="Ssl" />
      <sslProtocols>Tls10,Tls11,Tls12</sslProtocols>
      <requestFiltering allowDoubleEscaping="true">
        <!-- INTENTIONAL: 999999999 bytes (~1 GB) enables large-body DoS -->
        <requestLimits maxAllowedContentLength="999999999" />
      </requestFiltering>
    </security>

    <httpProtocol>
      <customHeaders>
        <!-- INTENTIONAL: no <remove name="Server" />, no <remove name="X-Powered-By" />,
             no Strict-Transport-Security, no X-Content-Type-Options, no X-Frame-Options.
             Only a cache hint is set, so banners leak and clickjacking/MIME-sniff are open. -->
        <add name="Cache-Control" value="no-cache" />
      </customHeaders>
    </httpProtocol>

    <handlers>
      <add name="aspx-isapi" path="*.aspx" verb="*"
           modules="IsapiModule"
           scriptProcessor="%windir%\Microsoft.NET\Framework64\v4.0.30319\aspnet_isapi.dll"
           resourceType="Unspecified" />
    </handlers>

    <modules runAllManagedModulesForAllRequests="true" />
  </system.webServer>
</configuration>
