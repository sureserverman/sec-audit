        "severity": {"from": "code", "lookup": {"S102": "HIGH", "S301": "HIGH", "S307": "HIGH", "S501": "HIGH", "S506": "HIGH", "S605": "HIGH", "S606": "HIGH", "S608": "HIGH", "S701": "HIGH"}, "default": "MEDIUM"},
        "cwe": {"from": "code", "lookup": {"S102": "CWE-95", "S307": "CWE-95", "S301": "CWE-502", "S506": "CWE-502", "S608": "CWE-89", "S605": "CWE-78", "S606": "CWE-78", "S105": "CWE-798", "S106": "CWE-798", "S311": "CWE-338", "S324": "CWE-327", "S501": "CWE-295", "S701": "CWE-79"}, "default": null},
        "title": "message", "file": "filename", "line": "location.row",
        "evidence": {"from": "message", "truncate": 200},
        "reference_url": {"from": "url", "default": null}
