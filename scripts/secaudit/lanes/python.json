        "evidence": {"concat": [{"from": "_parent.name"}, " ", {"from": "_parent.version"}, " — ", {"from": "id"}]},
        "reference_url": {"concat": ["https://osv.dev/vulnerability/", {"from": "id"}]},
        "fix_recipe": {"concat": ["upgrade to >=", {"from": "fix_versions.0"}]}
      }
    }
  ]
