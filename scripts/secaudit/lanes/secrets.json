{
  "lane": "secrets", "status_key": "__secrets_status__", "origin": "secrets", "reference": "secrets-tools.md",
  "finding_const": {"fix_recipe": null},
  "tools": [
    {
      "name": "gitleaks", "probe": "gitleaks",
      "invoke": ["gitleaks", "dir", "{target}", "--report-format", "json", "--report-path", "{tmp}/gitleaks.json", "--exit-code", "0", "--redact", "--no-banner"],
      "output": "file:{tmp}/gitleaks.json",
      "const": {"confidence": "high", "severity": "HIGH", "cwe": "CWE-798", "reference_url": "https://github.com/gitleaks/gitleaks"},
      "map": {
        "id": {"concat": ["gitleaks:", {"from": "RuleID"}]},
        "title": "Description",
        "file": "File",
        "line": "StartLine",
        "evidence": {"from": "Match", "truncate": 200}
      }
    },
    {
      "name": "trufflehog", "probe": "trufflehog",
      "applicable_when": "git-repo", "inapplicable_reason": "no-git-history",
      "invoke": ["trufflehog", "git", "file://{target}", "--json", "--no-verification"],
      "output": "stdout", "input_format": "jsonl",
      "const": {"confidence": "high", "severity": "HIGH", "cwe": "CWE-798", "reference_url": null},
      "map": {
        "id": {"concat": ["trufflehog:", {"from": "DetectorName"}], "default": "trufflehog:unknown"},
        "title": {"concat": [{"from": "DetectorName"}, " secret detected"], "default": "trufflehog secret detected"},
        "file": "SourceMetadata.Data.Git.file",
        "line": "SourceMetadata.Data.Git.line",
        "evidence": "Redacted"
      }
    }
  ]
}
