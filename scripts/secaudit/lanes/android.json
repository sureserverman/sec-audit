{
  "lane": "android",
  "status_key": "__android_status__",
  "origin": "android",
  "reference": "mobile-tools.md",
  "finding_const": {
    "fix_recipe": null
  },
  "tools": [
    {
      "name": "mobsfscan",
      "probe": "mobsfscan",
      "invoke": [
        "mobsfscan",
        "--json",
        "--output",
        "-",
        "{target}"
      ],
      "output": "stdout",
      "findings_path": "results",
      "iterate": "values",
      "flatten": "files",
      "const": {
        "confidence": "medium"
      },
      "map": {
        "id": "_parent._key",
        "severity": {
          "from": "_parent.metadata.severity",
          "map": {
            "ERROR": "HIGH",
            "WARNING": "MEDIUM",
            "INFO": "LOW"
          },
          "default": "MEDIUM"
        },
        "cwe": {
          "from": "_parent.metadata.cwe",
          "before": ":",
          "default": null
        },
        "title": "_parent.metadata.description",
        "file": "file_path",
        "line": {
          "from": "match_lines.0",
          "default": 0
        },
        "evidence": {
          "from": "match_string",
          "default": ""
        },
        "reference_url": {
          "from": "_parent.metadata.reference",
          "default": null
        }
      }
    },
    {
      "name": "apkleaks",
      "probe": "apkleaks",
      "applicable_glob": "*.apk",
      "inapplicable_reason": "no-apk",
      "invoke": [
        "apkleaks",
        "-f",
        "{target}",
        "--json",
        "--output",
        "{tmp}/apkleaks.json"
      ],
      "output": "file:{tmp}/apkleaks.json",
      "findings_path": "results",
      "const": {
        "confidence": "high",
        "cwe": "CWE-312",
        "line": 0,
        "severity": "MEDIUM"
      },
      "map": {
        "id": {
          "concat": [
            "apkleaks:",
            {
              "from": "name"
            }
          ]
        },
        "title": "name",
        "evidence": {
          "from": "matches.0",
          "default": ""
        },
        "file": "name",
        "reference_url": null
      }
    },
    {
      "name": "android-lint",
      "probe": "lint",
      "input_format": "xml",
      "xml_item": "issue",
      "invoke": [
        "lint",
        "--xml",
        "-",
        "{target}"
      ],
      "output": "stdout",
      "const": {
        "confidence": "high"
      },
      "map": {
        "id": "id",
        "severity": {
          "from": "severity",
          "map": {
            "Fatal": "HIGH",
            "Error": "HIGH",
            "Warning": "MEDIUM",
            "Information": "LOW",
            "Informational": "LOW"
          },
          "default": "LOW"
        },
        "cwe": {
          "from": "id",
          "lookup": {
            "HardcodedDebugMode": "CWE-489",
            "AllowBackup": "CWE-200",
            "ExportedReceiver": "CWE-926",
            "ExportedService": "CWE-926",
            "ExportedContentProvider": "CWE-926",
            "SetJavaScriptEnabled": "CWE-749"
          },
          "default": null
        },
        "title": "message",
        "evidence": "message",
        "file": "location.file",
        "line": {
          "from": "location.line",
          "int": true,
          "default": 0
        },
        "reference_url": null
      }
    }
  ]
}
